// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  TRAVELER
  OPERATOR
  ADMIN
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  EXPIRED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum HoldGroupStatus {
  ACTIVE
  EXPIRED
  CONFIRMED
  CANCELLED
}

enum PaymentRecordStatus {
  INITIALIZED
  PENDING
  SUCCESS
  FAILED
  DISPUTED
  REFUNDED
}

enum RefundChannel {
  CASH
  VOUCHER
  PAYSTACK
  WALLET
}

enum RefundRecordStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AccountOwnerType {
  USER
  COMPANY
  PLATFORM
  SYSTEM
}

enum AccountCategory {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountStatus {
  NORMAL
  FROZEN
  SUSPENDED
  CLOSED
}

enum TransactionStatus {
  CREATED
  AUTHORIZED
  PENDING
  POSTED
  SETTLED
  REVERSED
  VOIDED
  FAILED
}

enum LedgerEntrySide {
  DEBIT
  CREDIT
}

enum LedgerEntryStatus {
  PENDING
  POSTED
  VOIDED
  REVERSED
}

enum ReservationStatus {
  ACTIVE
  EXPIRED
  CONSUMED
  CANCELLED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum OnboardingStep {
  COMPANY
  DOCUMENTS
  BANK
  PROFILE
  TERMS
}

enum OnboardingEventType {
  STEP_ENTERED
  STEP_COMPLETED
  STEP_SKIPPED
  ABANDONED
  VALIDATION_FAILED
}

enum BusinessType {
  SOLE_PROPRIETORSHIP
  LLC
  CORPORATION
  PARTNERSHIP
  COOPERATIVE
  OTHER
}

enum CompanyStatus {
  DRAFT
  PENDING_VERIFICATION
  VERIFIED
  ACTIVE
  SUSPENDED
  REJECTED
}

enum DocumentType {
  BUSINESS_REGISTRATION_CERTIFICATE
  TAX_CLEARANCE_CERTIFICATE
  BUSINESS_LICENSE
  TRANSPORT_OPERATING_PERMIT
  INSURANCE_CERTIFICATE
  AUTHORIZED_REPRESENTATIVE_LETTER
  BANK_STATEMENT
  OTHER
}

enum DocumentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum StaffRole {
  OWNER
  ADMIN
  MANAGER
  OPERATIONS
  FINANCE
  SUPPORT
}

// ============================================
// AUTHENTICATION MODELS (Existing)
// ============================================

model User {
  id            String   @id
  fullName      String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  phone         String?  @unique
  role          UserRole @default(TRAVELER)

  // Operator registration fields
  workEmail String? @unique
  workPhone String? @unique

  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  sessions         Session[]
  accounts         Account[]
  refreshTokens    RefreshToken[]
  operatorProfiles Operator[]
  passengerProfile PassengerProfile?

  // Admin verification actions performed by this user
  verificationsPerformed       CompanyDocument[]     @relation("DocumentReviewedBy")
  companiesVerified            Company[]             @relation("CompanyVerifiedBy")
  bankAccountsVerified         BankAccount[]         @relation("BankAccountVerifiedBy")
  companyVerificationsReviewed CompanyVerification[] @relation("CompanyVerificationReviewer")

  // Staff & Activity relations
  sentInvitations     StaffInvitation[] @relation("InvitedBy")
  acceptedInvitations StaffInvitation[] @relation("AcceptedBy")
  activityLogs        ActivityLog[]
  bankAccessLogs      BankAccessLog[]

  bookings   Booking[]
  holdGroups HoldGroup[]
  reviews    Review[]

  @@index([role])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model RateLimit {
  id          String @id
  key         String @unique
  count       Int
  lastRequest BigInt

  @@map("rate_limit")
}


model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// OPERATOR REGISTRATION MODELS
// ============================================

model Company {
  id                 String       @id @default(cuid())
  name               String
  slug               String       @unique
  email              String       @unique
  phone              String       @unique
  website            String?
  description        String?
  businessType       BusinessType @default(SOLE_PROPRIETORSHIP)
  registrationNumber String       @unique
  taxId              String       @unique
  yearEstablished    Int?
  logoUrl            String?
  estimatedStaffSize Int

  // Status & Verification
  status          CompanyStatus @default(DRAFT)
  verifiedAt      DateTime?
  // Proper FK relation — no free-text admin ID string
  verifiedById    String?
  verifiedBy      User?         @relation("CompanyVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  rejectionReason String?

  // Legal acceptance timestamps + version tracking
  termsAcceptedAt      DateTime?
  commissionAcceptedAt DateTime?
  privacyAcceptedAt    DateTime?
  termsVersion         String?
  privacyVersion       String?
  commissionVersion    String?

  // Relations
  locations      CompanyLocation[]    @relation("CompanyLocations")
  documents      CompanyDocument[]
  bankAccounts   BankAccount[]
  operators      Operator[]
  invitations    StaffInvitation[]
  activityLogs   ActivityLog[]
  bankAccessLogs BankAccessLog[]
  verification   CompanyVerification?

  // Fleet & Operations
  fleet           Bus[]
  layoutTemplates SeatLayoutTemplate[] @relation("CompanyLayoutTemplates")
  routes          Route[]
  schedules       Schedule[]
  trips           Trip[]
  bookings        Booking[]
  reviews         Review[]
  holdGroups      HoldGroup[]

  // Paystack transfer recipient for manual settlements
  paystackTransferRecipientCode String?

  settlementPolicyId String?
  settlementPolicy   SettlementPolicy? @relation(fields: [settlementPolicyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([registrationNumber])
  @@index([taxId])
  @@map("company")
}

// CompanyLocation is defined further below with full terminal + city support

model CompanyDocument {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Document Details
  type     DocumentType
  fileName String
  fileUrl  String // S3/Cloudflare URL
  fileSize Int // Bytes
  mimeType String // application/pdf, image/jpeg, etc.

  // Verification — proper FK to User
  status       DocumentStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?          @relation("DocumentReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  notes        String?

  // Expiry (for permits, insurance)
  expiresAt      DateTime?
  reminderSentAt DateTime?

  // Versioning — new upload supersedes old; old document retained for audit
  isCurrent    Boolean           @default(true)
  supersededAt DateTime?
  replacedById String?
  replacedBy   CompanyDocument?  @relation("DocumentReplacement", fields: [replacedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replaces     CompanyDocument[] @relation("DocumentReplacement")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([type])
  @@index([status])
  @@index([isCurrent])
  @@map("company_document")
}

model BankAccount {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Bank Details
  bankName           String
  bankCode           String?
  // Encrypted at rest (enc:v1: prefix) — see apps/web/lib/bank-crypto.ts
  accountNumber      String
  accountNumberLast4 String?
  accountName        String // Must match company name
  branch             String?
  swiftCode          String?
  iban               String?

  // Verification — proper FK to User
  isVerified             Boolean   @default(false)
  verifiedAt             DateTime?
  verifiedById           String?
  verifiedBy             User?     @relation("BankAccountVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)
  verificationDocumentId String? // Link to CompanyDocument

  // Status
  isActive                      Boolean @default(true)
  isDefault                     Boolean @default(false)
  paystackTransferRecipientCode String?

  // External verification metadata
  verificationProvider  String? // e.g. "PAYSTACK", "FLUTTERWAVE"
  verifiedByProvider    Boolean   @default(false)
  verificationReference String?
  verificationPayload   Json?
  lastVerificationAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bankName, accountNumber])
  @@index([companyId])
  @@map("bank_account")
}

model BankAccessLog {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  ip        String?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@map("bank_access_log")
}

model CompanyVerification {
  id        String  @id @default(cuid())
  companyId String  @unique
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  ownerIdentityVerified Boolean @default(false)
  bankVerified          Boolean @default(false)
  documentsVerified     Boolean @default(false)
  permitVerified        Boolean @default(false)

  reviewedById String?
  reviewedBy   User?     @relation("CompanyVerificationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?

  @@map("company_verification")
}

model Operator {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Company Link
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Role & Status
  role       StaffRole      @default(OWNER)
  status     OperatorStatus @default(ACTIVE)
  isActive   Boolean        @default(true)
  isVerified Boolean        @default(false)
  deletedAt  DateTime?

  // Onboarding status and tracking
  onboardingStatus   OnboardingStatus          @default(NOT_STARTED)
  onboardingProgress OperatorOnboarding?
  onboardingEvents   OperatorOnboardingEvent[]

  // Personal Details
  dateOfBirth          DateTime?
  nationalIdNumber     String?
  nationalIdType       String? // passport | national_id | driver_license
  nationalIdDocumentId String? // Link to CompanyDocument

  // Contact
  personalPhone         String?
  emergencyContactName  String?
  emergencyContactPhone String?

  // Profile
  profilePhotoUrl String?
  jobTitle        String?

  // Timestamps
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@index([role])
  @@map("operator")
}

// ============================================
// OPERATOR ONBOARDING PROGRESS
// ============================================

model OperatorOnboarding {
  id         String   @id @default(cuid())
  operatorId String   @unique
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  currentStep        OnboardingStep @default(COMPANY)
  completedSteps     Json           @default("[]")
  completedStepCount Int            @default(0)
  totalSteps         Int            @default(5)

  startedAt   DateTime  @default(now())
  lastSeenAt  DateTime  @updatedAt
  completedAt DateTime?

  @@index([operatorId])
  @@map("operator_onboarding")
}

model OperatorOnboardingEvent {
  id         String   @id @default(cuid())
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  step             OnboardingStep
  eventType        OnboardingEventType
  timeSpentSeconds Int?
  metadata         Json?
  device           String?
  ip               String?

  createdAt DateTime @default(now())

  @@index([operatorId])
  @@index([step, eventType])
  @@map("operator_onboarding_event")
}

// Transient: deleted after successful account creation
model PendingOperatorSignup {
  id          String    @id @default(cuid())
  companyName String
  ownerName   String
  email       String    @unique
  phone       String
  country     String
  otpHash     String
  expiresAt   DateTime
  attempts    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([email])
  @@index([expiresAt])
  @@map("pending_operator_signup")
}

// ============================================
// ENUMS — FLEET & OPERATIONS
// ============================================

enum BusStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}

enum SeatType {
  PASSENGER_WINDOW
  PASSENGER_AISLE
  PASSENGER_MIDDLE
  DRIVER_AREA
  EMPTY_SPACE
}

enum SeatClass {
  ECONOMY
  STANDARD
  VIP
}

enum RouteStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum RecurrenceType {
  DAILY
  WEEKDAYS
  WEEKENDS
  CUSTOM
}

enum ExceptionType {
  CANCELLED
  EXTRA_SERVICE
  MODIFIED
}

enum ExceptionReason {
  HOLIDAY_ISLAMIC
  HOLIDAY_CHRISTIAN
  HOLIDAY_NATIONAL
  STRIKE
  WEATHER
  MAINTENANCE
  OPERATIONAL
  OTHER
}

enum FareType {
  FIXED
  PROMO
  HOLIDAY_SURGE
  EARLY_BIRD
}

enum TripStatus {
  SCHEDULED
  BOARDING
  DEPARTED
  ARRIVED
  CANCELLED
  DELAYED
}

enum SeatStatus {
  AVAILABLE
  HELD
  BOOKED
  BLOCKED
}

// ============================================
// CITIES (Platform-seeded — Côte d'Ivoire only)
// ============================================

model City {
  id         String  @id @default(cuid())
  name       String // French (official language of CI)
  nameEn     String? // Optional English for future use
  region     String // e.g. "Vallée du Bandama"
  district   String // e.g. "Savanes"
  latitude   Float?
  longitude  Float?
  isActive   Boolean @default(true)
  isMajorHub Boolean @default(false) // Abidjan, Bouaké, Yamoussoukro, etc.

  locations CompanyLocation[]

  @@unique([name])
  @@index([isActive])
  @@map("city")
}

// ============================================
// COMPANY LOCATION (extended — terminal promotion)
// ============================================
// CompanyLocation already holds operator depots from onboarding.
// Adding cityId FK + isTerminal flag promotes a location to a
// bookable passenger terminal without a separate model.

model CompanyLocation {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation("CompanyLocations", fields: [companyId], references: [id], onDelete: Cascade)

  // Link to canonical CI city
  cityId       String?
  cityRelation City?   @relation(fields: [cityId], references: [id])

  // Terminal promotion — operator checks this in the dashboard
  isTerminal Boolean @default(false)

  // Location Details
  name         String
  addressLine1 String
  addressLine2 String?
  city         String? // Keep the original field name as optional to avoid data loss warning
  state        String?
  postalCode   String?
  country      String  @default("Cote d'Ivoire")
  latitude     Float?
  longitude    Float?

  // Contact
  phone        String
  managerName  String?
  managerPhone String?
  managerEmail String?

  // Operational
  isPrimary      Boolean @default(false)
  operatingHours Json?
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Route relations
  originRoutes Route[]         @relation("RouteOriginTerminal")
  destRoutes   Route[]         @relation("RouteDestTerminal")
  waypoints    RouteWaypoint[]
  tripStops    TripStop[]

  @@index([companyId])
  @@index([cityId])
  @@index([isTerminal])
  @@index([isPrimary])
  @@map("company_location")
}

// ============================================
// FLEET — BUS TYPE & SEAT LAYOUT TEMPLATES
// ============================================

model BusType {
  id          String  @id @default(cuid())
  name        String // "Toyota Coaster", "Yutong ZK6107", "Mercedes Sprinter"
  description String?
  isActive    Boolean @default(true)

  layoutTemplates SeatLayoutTemplate[]
  buses           Bus[]

  @@unique([name])
  @@map("bus_type")
}

model SeatLayoutTemplate {
  id        String  @id @default(cuid())
  busTypeId String
  busType   BusType @relation(fields: [busTypeId], references: [id])

  // null = platform default; set = operator custom layout
  companyId String?
  company   Company? @relation("CompanyLayoutTemplates", fields: [companyId], references: [id])

  name       String // "Coaster Standard 22", "Coach VIP 18", "Coach 2+2 45"
  totalSeats Int
  rows       Int
  columns    Int
  hasAC      Boolean @default(false)
  hasWifi    Boolean @default(false)
  hasToilet  Boolean @default(false)
  hasLuggage Boolean @default(true)

  seatTemplates SeatTemplate[]
  buses         Bus[]

  @@index([busTypeId])
  @@index([companyId])
  @@map("seat_layout_template")
}

model SeatTemplate {
  id       String             @id @default(cuid())
  layoutId String
  layout   SeatLayoutTemplate @relation(fields: [layoutId], references: [id], onDelete: Cascade)

  row        Int
  col        Int
  deck       Int      @default(1)
  label      String // "1A", "1B", "2A" — shown to operators and passengers
  seatType   SeatType @default(PASSENGER_WINDOW)
  isBookable Boolean  @default(true)

  @@index([layoutId])
  @@map("seat_template")
}

// ============================================
// FLEET — BUS & SEATS
// ============================================

model Bus {
  id               String             @id @default(cuid())
  companyId        String
  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  busTypeId        String
  busType          BusType            @relation(fields: [busTypeId], references: [id])
  layoutTemplateId String
  layoutTemplate   SeatLayoutTemplate @relation(fields: [layoutTemplateId], references: [id])

  registrationPlate String    @unique
  internalName      String? // "Bus Alpha", operator's own reference
  manufactureYear   Int?
  status            BusStatus @default(ACTIVE)
  notes             String?

  seats Seat[]
  trips Trip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@map("bus")
}

model Seat {
  id    String @id @default(cuid())
  busId String
  bus   Bus    @relation(fields: [busId], references: [id], onDelete: Cascade)

  row      Int
  col      Int
  deck     Int      @default(1)
  label    String // "1A", "2B" — copied from SeatTemplate, operator can rename
  seatType SeatType
  isActive Boolean  @default(true) // false = blocked/damaged

  tripSeats TripSeat[]
  bookings  Booking[]

  @@index([busId])
  @@map("seat")
}

// ============================================
// ROUTES & WAYPOINTS
// ============================================

model Route {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name String // "Abidjan – Bouaké Express"

  originTerminalId String
  originTerminal   CompanyLocation @relation("RouteOriginTerminal", fields: [originTerminalId], references: [id])

  destTerminalId String
  destTerminal   CompanyLocation @relation("RouteDestTerminal", fields: [destTerminalId], references: [id])

  distanceKm       Float?
  estimatedMinutes Int?

  status RouteStatus @default(DRAFT)

  waypoints RouteWaypoint[]
  schedules Schedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([originTerminalId])
  @@index([destTerminalId])
  @@map("route")
}

model RouteWaypoint {
  id         String          @id @default(cuid())
  routeId    String
  route      Route           @relation(fields: [routeId], references: [id], onDelete: Cascade)
  terminalId String
  terminal   CompanyLocation @relation(fields: [terminalId], references: [id])

  stopOrder              Int // 0 = origin, 1..N-1 = intermediate, N = destination
  arrivalOffsetMinutes   Int // minutes after origin departure: arrive at this stop
  departureOffsetMinutes Int // minutes after origin departure: leave this stop
  distanceFromOriginKm   Float?
  isPickup               Boolean @default(true) // passengers can board here
  isDropoff              Boolean @default(true) // passengers can alight here

  @@unique([routeId, stopOrder])
  @@index([routeId])
  @@index([terminalId])
  @@map("route_waypoint")
}

// ============================================
// SCHEDULES — TEMPLATES + CALENDAR
// ============================================

model Schedule {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  routeId   String
  route     Route   @relation(fields: [routeId], references: [id])

  name          String? // "Morning Express", "Night Service"
  departureTime String // "06:00" — HH:mm, CI timezone is UTC+0 (no DST)
  isActive      Boolean @default(true)

  // Bus NOT assigned here — assigned per Trip
  calendar   ServiceCalendar?
  exceptions ServiceException[]
  fares      Fare[]
  trips      Trip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([routeId])
  @@index([isActive])
  @@map("schedule")
}

model ServiceCalendar {
  id         String   @id @default(cuid())
  scheduleId String   @unique
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  monday    Boolean @default(false)
  tuesday   Boolean @default(false)
  wednesday Boolean @default(false)
  thursday  Boolean @default(false)
  friday    Boolean @default(false)
  saturday  Boolean @default(false)
  sunday    Boolean @default(false)

  validFrom  DateTime
  validUntil DateTime? // null = runs indefinitely

  @@map("service_calendar")
}

model ServiceException {
  id         String   @id @default(cuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  date   DateTime // the specific date affected (date only, time ignored)
  type   ExceptionType
  reason ExceptionReason @default(OPERATIONAL)
  notes  String?

  @@index([scheduleId])
  @@index([date])
  @@map("service_exception")
}

// ============================================
// FARES (extensible from v1)
// ============================================

model Fare {
  id         String   @id @default(cuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  type      FareType  @default(FIXED)
  seatClass SeatClass

  // Which segment this price covers (by waypoint stopOrder indices)
  // 0 → N = full route. 2 → N = board at intermediate stop 2.
  fromStopOrder Int @default(0)
  toStopOrder   Int

  priceXOF   Int // price in CFA Francs — always XOF for CI
  validFrom  DateTime?
  validUntil DateTime?
  isActive   Boolean   @default(true)

  @@index([scheduleId])
  @@index([type])
  @@map("fare")
}

// ============================================
// TRIPS — THE OPERATIONAL ENTITY
// ============================================

model Trip {
  id         String   @id @default(cuid())
  scheduleId String
  schedule   Schedule @relation(fields: [scheduleId], references: [id])
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id])

  // Bus assigned PER TRIP — not per schedule (maintenance/swap support)
  busId String
  bus   Bus    @relation(fields: [busId], references: [id])

  // Schedule-derived but stored immutably on trip creation
  departureDate DateTime // full timestamp: 2025-08-15T06:00:00Z

  // Operational tracking
  estimatedArrival DateTime?
  actualDeparture  DateTime?
  actualArrival    DateTime?
  delayMinutes     Int?
  gate             String? // physical bay/gate at origin terminal
  status           TripStatus @default(SCHEDULED)
  cancelReason     String?
  notes            String?

  // Route snapshot frozen at trip creation — protects historical bookings
  // if the route is later edited or deleted
  routeSnapshotJson Json

  totalSeats Int

  tripStops  TripStop[]
  seats      TripSeat[]
  bookings   Booking[]
  holdGroups HoldGroup[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([scheduleId])
  @@index([busId])
  @@index([status])
  @@index([departureDate])
  @@map("trip")
}

// TripStops — instantiated from RouteWaypoints when a trip is created.
// Search queries these for intermediate boarding (Daloa → Man on an Abidjan → Man bus).

model TripStop {
  id         String          @id @default(cuid())
  tripId     String
  trip       Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  terminalId String
  terminal   CompanyLocation @relation(fields: [terminalId], references: [id])

  stopOrder          Int
  scheduledArrival   DateTime? // computed from departureDate + arrivalOffset
  scheduledDeparture DateTime? // computed from departureDate + departureOffset
  actualArrival      DateTime?
  actualDeparture    DateTime?
  isPickup           Boolean   @default(true)
  isDropoff          Boolean   @default(true)

  originBookings      Booking[] @relation("BookingOriginStop")
  destinationBookings Booking[] @relation("BookingDestStop")

  @@unique([tripId, stopOrder])
  @@index([tripId])
  @@index([terminalId])
  @@map("trip_stop")
}

model TripSeat {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  seatId String
  seat   Seat   @relation(fields: [seatId], references: [id])

  isActive      Boolean @default(true) // false = blocked/damaged
  blockedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tripId, seatId])
  @@index([tripId])
  @@index([tripId, isActive])
  @@map("trip_seat")
}

// ============================================
// CHECKOUT & PAYMENTS
// ============================================

model PlatformSettings {
  id String @id @default("default")

  defaultCommissionBps      Int @default(500) // 5.00%
  defaultConvenienceFeeBps  Int @default(250) // 2.50%
  paystackFeeLocalCardBps   Int @default(320)
  paystackFeeIntlCardBps    Int @default(380)
  paystackFeeMobileMoneyBps Int @default(195)

  // Withdrawal Limits
  minWithdrawalAmount      Int @default(5000) // Minimum amount an operator can withdraw
  withdrawalFrequencyHours Int @default(24) // How often an operator can withdraw

  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model CommissionDistanceTier {
  id            String  @id @default(cuid())
  label         String
  minDistanceKm Float
  maxDistanceKm Float?
  commissionBps Int
  sortOrder     Int     @default(0)
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@map("commission_distance_tier")
}

model HoldGroup {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tripId    String
  trip      Trip    @relation(fields: [tripId], references: [id])
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  offerId       String
  status        HoldGroupStatus @default(ACTIVE)
  holdExpiresAt DateTime
  seatCount     Int
  baseFareXOF   Int // per seat, tax-inclusive

  bookings        Booking[]
  pricingSnapshot PricingSnapshot?
  payment         ExternalPayment?
  refunds         Refund[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([tripId])
  @@index([userId])
  @@index([status, holdExpiresAt])
  @@map("hold_group")
}

model PricingSnapshot {
  id          String    @id @default(cuid())
  holdGroupId String    @unique
  holdGroup   HoldGroup @relation(fields: [holdGroupId], references: [id], onDelete: Cascade)

  distanceKm        Float?
  commissionBps     Int
  convenienceFeeBps Int
  baseFareXOF       Int
  seatCount         Int
  subtotalBaseXOF   Int
  convenienceFeeXOF Int
  chargeAmountXOF   Int
  commissionXOF     Int
  operatorNetXOF    Int
  platformGrossXOF  Int
  snapshotJson      Json?

  createdAt DateTime @default(now())

  @@map("pricing_snapshot")
}

model ExternalPayment {
  id          String     @id @default(cuid())
  holdGroupId String?    @unique
  holdGroup   HoldGroup? @relation(fields: [holdGroupId], references: [id], onDelete: Cascade)

  provider          String
  amountXOF         Int
  status            PaymentRecordStatus @default(INITIALIZED)
  paystackReference String?             @unique
  channel           String?
  feesXOF           Int?
  metadata          Json?
  confirmedAt       DateTime?

  attempts     PaymentAttempt[]
  events       PaymentEvent[]
  refunds      Refund[]
  transactions FinancialTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([paystackReference])
  @@map("payment")
}

model PaymentAttempt {
  id                String              @id @default(cuid())
  paymentId         String
  payment           ExternalPayment     @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  attemptNumber     Int
  paystackReference String              @unique
  status            PaymentRecordStatus @default(INITIALIZED)
  channel           String?
  failureReason     String?
  metadata          Json?

  createdAt DateTime @default(now())

  @@unique([paymentId, attemptNumber])
  @@index([paymentId])
  @@map("payment_attempt")
}

model PaymentEvent {
  id        String          @id @default(cuid())
  paymentId String
  payment   ExternalPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  eventType String
  payload   Json
  createdAt DateTime        @default(now())

  @@index([paymentId])
  @@map("payment_event")
}

model WebhookEvent {
  id             String    @id @default(cuid())
  provider       String
  eventType      String
  idempotencyKey String    @unique
  reference      String?
  payload        Json
  processedAt    DateTime?
  error          String?

  createdAt DateTime @default(now())

  @@index([provider, createdAt])
  @@map("webhook_event")
}

model Refund {
  id          String          @id @default(cuid())
  holdGroupId String
  holdGroup   HoldGroup       @relation(fields: [holdGroupId], references: [id], onDelete: Cascade)
  paymentId   String
  payment     ExternalPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  amountXOF        Int
  channel          RefundChannel
  status           RefundRecordStatus @default(PENDING)
  paystackRefundId String?
  reason           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([holdGroupId])
  @@index([paymentId])
  @@map("refund")
}

// ============================================
// FINANCIAL CORE (DOUBLE-ENTRY LEDGER)
// ============================================

model FinancialAccount {
  id String @id @default(cuid())

  // Generic Ownership (Allows multiple accounts per owner)
  ownerType AccountOwnerType
  ownerId   String // e.g., userId or companyId

  accountCategory      AccountCategory
  accountClass         String // e.g., "PASSENGER_WALLET", "OPERATOR_RECEIVABLE", "LOYALTY_POINTS" (Data-driven)
  currency             String          @default("XOF")
  status               AccountStatus   @default(NORMAL)
  allowNegativeBalance Boolean         @default(false)

  // ⚠️ READ MODEL: Derived Cache. Mutated EXCLUSIVELY by AccountingEngine
  postedBalance    BigInt @default(0) // Total settled
  reservedBalance  BigInt @default(0) // Locked in reservations
  availableBalance BigInt @default(0) // posted - reserved

  ledgerEntries LedgerEntry[]
  reservations  WalletReservation[]
  snapshots     FinancialAccountSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([ownerType, ownerId, accountCategory, accountClass, currency])
  @@index([ownerType, ownerId])
  @@map("financial_account")
}

model FinancialAccountSnapshot {
  id        String           @id @default(cuid())
  accountId String
  account   FinancialAccount @relation(fields: [accountId], references: [id])

  period           String // "DAILY", "WEEKLY", "MONTHLY"
  snapshotDate     DateTime
  postedBalance    BigInt
  reservedBalance  BigInt
  availableBalance BigInt

  createdAt DateTime @default(now())

  @@unique([accountId, period, snapshotDate])
  @@map("financial_account_snapshot")
}

model FinancialTransaction {
  id     String            @id @default(cuid())
  type   String // Business Event: e.g., "BOOKING", "TOP_UP", "REFUND"
  status TransactionStatus @default(CREATED)

  // Explicit infrastructure linkage
  externalPaymentId String?
  externalPayment   ExternalPayment? @relation(fields: [externalPaymentId], references: [id])

  currency    String  @default("XOF")
  description String?
  metadata    Json?

  entries LedgerEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([externalPaymentId, type])
  @@map("financial_transaction")
}

model LedgerEntry {
  id            String               @id @default(cuid())
  transactionId String
  transaction   FinancialTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  accountId String
  account   FinancialAccount @relation(fields: [accountId], references: [id])

  side     LedgerEntrySide
  amount   BigInt
  currency String            @default("XOF")
  status   LedgerEntryStatus @default(POSTED)

  sequenceNumber Int
  description    String?
  referenceType  String? // e.g., "BOOKING_ID"
  referenceId    String?
  effectiveAt    DateTime @default(now())
  idempotencyKey String   @unique

  createdAt DateTime @default(now())

  @@unique([transactionId, sequenceNumber])
  @@map("ledger_entry")
}

model WalletReservation {
  id        String           @id @default(cuid())
  accountId String
  account   FinancialAccount @relation(fields: [accountId], references: [id])

  holdGroupId String?

  amount    Int
  currency  String            @default("XOF")
  status    ReservationStatus @default(ACTIVE)
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([holdGroupId])
  @@map("wallet_reservation")
}

model SettlementPolicy {
  id              String  @id @default(cuid())
  name            String
  type            String // "TIME_BASED", "THRESHOLD_BASED", "MANUAL"
  isDefault       Boolean @default(false)
  isActive        Boolean @default(true)
  priority        Int     @default(0)
  thresholdAmount Int?
  cronSchedule    String?

  companies Company[]

  @@map("settlement_policy")
}

// ============================================
// BOOKINGS
// ============================================

model Booking {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tripId    String
  trip      Trip    @relation(fields: [tripId], references: [id])
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  seatId    String
  seat      Seat    @relation(fields: [seatId], references: [id])

  // Segment relations
  originTripStopId      String
  originTripStop        TripStop @relation("BookingOriginStop", fields: [originTripStopId], references: [id])
  destinationTripStopId String
  destinationTripStop   TripStop @relation("BookingDestStop", fields: [destinationTripStopId], references: [id])
  boardingStopOrder     Int
  dropoffStopOrder      Int

  // Holding & Reservation
  status        BookingStatus @default(PENDING_PAYMENT)
  holdExpiresAt DateTime? // Null for confirmed bookings; set for holds
  issuedAt      DateTime? // When the ticket was actually issued (after payment)

  // Booking details
  farePaid         Int // price paid in XOF
  paymentStatus    PaymentStatus @default(UNPAID)
  bookingReference String        @unique // e.g. MR-7K4P92
  passengerName    String
  passengerPhone   String
  ticketToken      String        @unique @default(cuid()) // used to generate QR code dynamically

  // Multi-seat checkout grouping
  holdGroupId      String?
  holdGroup        HoldGroup?      @relation(fields: [holdGroupId], references: [id], onDelete: SetNull)
  savedPassengerId String?
  savedPassenger   SavedPassenger? @relation(fields: [savedPassengerId], references: [id], onDelete: SetNull)

  // Review relation
  review Review?

  // Tracking
  checkedInAt DateTime?
  boardedAt   DateTime?
  completedAt DateTime?
  clearedAt   DateTime? // Escrow clearance (when funds become available for withdrawal)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([tripId, seatId, status])
  @@index([tripId, status])
  @@index([tripId, seatId, originTripStopId, destinationTripStopId])
  @@index([userId])
  @@index([holdGroupId])
  @@map("booking")
}

// Expanded from stub in Phase 4
model Review {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  rating   Int
  content  String?
  authorId String
  author   User    @relation(fields: [authorId], references: [id])

  bookingId String?  @unique
  booking   Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("review")
}

model PassengerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  marketingOptIn   Boolean @default(false)
  preferencesJson  Json?
  stripeCustomerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedPassengers SavedPassenger[]

  @@map("passenger_profile")
}

model SavedPassenger {
  id        String           @id @default(cuid())
  profileId String
  profile   PassengerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  fullName    String
  phone       String
  email       String?
  label       String?
  dateOfBirth DateTime?
  idType      String?
  idNumber    String?
  isSelf      Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([profileId])
  @@map("saved_passenger")
}

model StaffInvitation {
  id           String           @id @default(cuid())
  email        String
  role         StaffRole        @default(OPERATIONS)
  jobTitle     String?
  message      String?
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  token        String           @unique
  expiresAt    DateTime
  status       InvitationStatus @default(PENDING)
  invitedById  String
  invitedBy    User             @relation("InvitedBy", fields: [invitedById], references: [id])
  acceptedById String?
  acceptedBy   User?            @relation("AcceptedBy", fields: [acceptedById], references: [id])
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([companyId])
  @@index([email])
  @@index([token])
  @@map("staff_invitation")
}

model ActivityLog {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String
  description String
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@map("activity_log")
}

enum OperatorStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}
