{
  "name": "@moja/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Shared Prisma client access for Moja Buss workspaces.",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "echo \"No build configured for @moja/db\"",
    "lint": "biome check package.json tsconfig.json src",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests configured for @moja/db\"",
    "generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@moja/config": "workspace:*",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.16.3",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@moja/typescript": "workspace:*",
    "prisma": "^7.8.0",
    "tsx": "^4.7.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
