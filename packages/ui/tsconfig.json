{
  "extends": "@moja/typescript/next.json",
  "compilerOptions": {
    "paths": {
      "#components/*": ["./src/components/*"],
      "#hooks/*": ["./src/hooks/*"],
      "#lib/*": ["./src/lib/*"]
    },
    "noImplicitAny": false
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"],
  "exclude": ["node_modules"]
}
