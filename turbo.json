{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "BETTER_AUTH_SECRET",
    "PAYSTACK_SECRET_KEY",
    "NOVU_SECRET_KEY",
    "CRON_SECRET",
    "BANK_ENCRYPTION_KEY",
    "BETTER_AUTH_URL",
    "APP_URL",
    "WITHDRAWAL_2FA_PEPPER",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_BUCKET",
    "S3_PUBLIC_URL_BASE"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "build/**"]
    },
    "lint": {},
    "typecheck": {},
    "test": {},
    "clean": {
      "cache": false
    }
  }
}
